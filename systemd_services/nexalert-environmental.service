[Unit]
Description=NexAlert Environmental Monitor
After=nexalert.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/nexalert_v3
Environment="PATH=/home/pi/nexalert_v3/venv/bin"
ExecStart=/home/pi/nexalert_v3/venv/bin/python3 /home/pi/nexalert_v3/backend/services/environmental_monitor.py
Restart=always
RestartSec=30
StandardOutput=append:/home/pi/nexalert_v3/logs/environmental.log
StandardError=append:/home/pi/nexalert_v3/logs/environmental_error.log

[Install]
WantedBy=multi-user.target
