# NexAlert v3.0 - Environment Configuration Template
# Copy this file to .env and update with your values

# Server Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Database
DATABASE_URL=sqlite:////opt/nexalert/database/nexalert.db
DATABASE_BACKUP_PATH=/opt/nexalert/backups

# Server Port
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# CORS Configuration
CORS_ORIGINS=*

# SocketIO Configuration
SOCKETIO_ASYNC_MODE=eventlet
SOCKETIO_PING_TIMEOUT=120
SOCKETIO_PING_INTERVAL=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=/opt/nexalert/logs/nexalert.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=7

# JWT Token Configuration
JWT_EXPIRATION_DAYS=30
JWT_ALGORITHM=HS256

# Geolocation
ENABLE_GPS=True
GPS_ACCURACY_THRESHOLD=50

# Sensor Data
ENABLE_SENSOR_LOGGING=True
SENSOR_READ_INTERVAL=60

# Email Notifications (Optional)
ENABLE_EMAIL=False
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# SMS Notifications (Optional)
ENABLE_SMS=False
TWILIO_ACCOUNT_SID=your-sid-here
TWILIO_AUTH_TOKEN=your-token-here
TWILIO_PHONE_NUMBER=+1234567890

# Google Maps API
GOOGLE_MAPS_API_KEY=your-api-key-here
MAP_DEFAULT_CENTER_LAT=0
MAP_DEFAULT_CENTER_LON=0
MAP_DEFAULT_ZOOM=13

# Network Configuration
MESH_NETWORK_SSID=NexAlert-Emergency
MESH_GATEWAY_IP=10.42.0.1
MESH_SUBNET=10.42.0.0/24
MESH_DHCP_RANGE_START=10.42.0.50
MESH_DHCP_RANGE_END=10.42.0.150

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_NUMBERS=True
PASSWORD_REQUIRE_SPECIAL=False

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# SOS Alert Configuration
SOS_BROADCAST_RADIUS_METERS=5000
SOS_ALERT_TIMEOUT_MINUTES=1440
SOS_AUTO_ACKNOWLEDGE_AFTER_MINUTES=0

# Debug Mode (DO NOT USE IN PRODUCTION)
DEBUG=False
DEBUG_SQL_QUERIES=False

# Optional: Admin Settings
ADMIN_EMAIL=admin@nexalert.local
MAINTENANCE_MODE=False
